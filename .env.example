# GHOST OSINT Engine — Environment Configuration
# Copy to .env and fill in your values

# ── AI Enrichment (choose one) ──
# OpenRouter (recommended, pay-per-use)
OPENROUTER_API_KEY=

# Or use local Hermes Agent (no key needed, uses GHOST_ENRICH_MODE=file)

# ── Face Recognition ──
# FaceOnLive (PimEyes-like): https://faceonlive.com
FACEONLIVE_API_KEY=

# Azure Face API (free tier: 30k/mo): https://azure.microsoft.com
AZURE_FACE_API_KEY=
AZURE_FACE_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com

# ── Data Breach Search ──
# HaveIBeenPwned (free): https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# DeHashed (paid): https://dehashed.com/api
DEHASHED_API_KEY=
DEHASHED_EMAIL=

# LeakCheck (paid): https://leakcheck.io
LEAKCHECK_API_KEY=

# ── Telegram Bot ──
# Get from @BotFather: https://t.me/BotFather
GHOST_BOT_TOKEN=

# ── API Security ──
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
GHOST_API_KEY=
GHOST_ENRICH_KEY=

# ── Credits ──
GHOST_CREDITS_PER_SCAN=1
GHOST_CREDITS_PER_DEEP=3
GHOST_FREE_DAILY_SCANS=3
